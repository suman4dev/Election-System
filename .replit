modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
VITE_FIREBASE_API_KEY = "placeholder-replace-me"
VITE_FIREBASE_APP_ID = "1:000000000000:web:placeholder"
VITE_FIREBASE_AUTH_DOMAIN = "placeholder.firebaseapp.com"
VITE_FIREBASE_MESSAGING_SENDER_ID = "000000000000"
VITE_FIREBASE_PROJECT_ID = "placeholder-replace-me"
VITE_FIREBASE_STORAGE_BUCKET = "placeholder.appspot.com"
