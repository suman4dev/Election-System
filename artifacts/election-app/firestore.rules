rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /election/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
      match /candidates/{candidateId} {
        allow read: if true;
        allow create, delete: if request.auth != null && request.auth.token.email != null;
        allow update: if request.auth != null && (
          (request.auth.token.email != null) ||
          (request.resource.data.voteCount == resource.data.voteCount + 1 &&
           request.resource.data.name == resource.data.name &&
           request.resource.data.photoUrl == resource.data.photoUrl)
        );
      }
    }
    // Booths: admin has full control; any signed-in session (kiosk anon auth)
    // can update unlocked + lastVoteAt so the 5-second auto-unlock works.
    match /booths/{boothId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
      allow update: if request.auth != null;
    }
  }
}
